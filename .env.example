APP_NAME=delayed-notifier
APP_VERSION=1.0.0
ENV=local

HTTP_HOST=0.0.0.0
HTTP_IDLE_TIMEOUT=60s
HTTP_MAX_HEADER_BYTES=1048576
HTTP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=5s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=5s

DB_BASE_RETRY_DELAY=100ms
DB_CONN_ATTEMPTS=5
DB_DSN=postgres://postgres:postgres@db:5432/notify_db?sslmode=disable
DB_HOST=db
DB_MAX_RETRY_DELAY=5s
DB_NAME=notify_db
DB_PASSWORD=postgres
DB_POOL_MAX=20
DB_PORT=5432
DB_SSL_MODE=disable
DB_USER=postgres

CACHE_ADDR=redis:6379
CACHE_DB=0
CACHE_DIAL_TIMEOUT=5s
CACHE_PASSWORD=
CACHE_POOL_SIZE=20
CACHE_READ_TIMEOUT=3s
CACHE_WRITE_TIMEOUT=3s

RABBIT_ADAPTIVE_POLLING=false
RABBIT_ATTEMPTS=3
RABBIT_BACKOFF=2.0
RABBIT_CONNECTION_NAME=delayed-notifier-publisher
RABBIT_CONNECT_TIMEOUT=30s
RABBIT_CONTENT_TYPE=application/json
RABBIT_DELAY=1s
RABBIT_EXCHANGE=notifications
RABBIT_HEARTBEAT=10s
RABBIT_PREFETCH=10
RABBIT_QUEUE_PROCESS_INTERVAL=5s
RABBIT_URL=amqp://guest:guest@rabbitmq:5672/
RABBIT_WORKERS=2

SERVICE_MAX_RETRIES=3
SERVICE_MAX_RETRY_EXPONENT=4
SERVICE_QUERY_LIMIT=10
SERVICE_RETRY_DELAY=5m

SMTP_FROM=yegorsandalov2004@mail.ru
SMTP_HOST=smtp.mail.ru
SMTP_PASSWORD=dQdqjITnVA4o0G2mwBPV
SMTP_PORT=465
SMTP_USERNAME=yegorsandalov2004@mail.ru

TG_ALIAS=notifyGolang_bot
